,"    \"\"\"Модель для хранения загруженных XML документов\"\"\"\n","    id: UUID = Field(default_factory=uuid4)\n","    parent_doc_id: str\n","    filename: str\n","    xml_content: str\n","    upload_timestamp: datetime = Field(default_factory=datetime.utcnow)\n","\n","class GeneratedResult(BaseModel):\n","    \"\"\"Модель для хранения результатов генерации LLM (XML или JSON)\"\"\"\n","    id: UUID = Field(default_factory=uuid4)\n","    parent_doc_id: str\n","    result_type: str # 'xml' или 'json'\n","    content: str\n","    created_at: datetime = Field(default_factory=datetime.utcnow)"],"metadata":{"id":"L_AP5d9fINsY","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778837315607,"user_tz":-420,"elapsed":73,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"ed1a1df1-11ed-440e-e5b9-30028de172db"},"execution_count":16,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing db_models.py\n"]}]},{"cell_type":"code","source":["# Переходим в папку Проекта\n","%cd {app_path}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778837331080,"user_tz":-420,"elapsed":27,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"81984f5b-1e9e-477a-dd10-b92dc95b0012","id":"chr7-6fQG_el"},"execution_count":17,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app\n"]}]},{"cell_type":"markdown","source":["## Cоздать базы данных SQLite и PostgreSQL"],"metadata":{"id":"jNzhOutQp9v1"}},{"cell_type":"code","source":["%%writefile db_main.py\n","\n","# @title Запуск ТОЛЬКО если нужно создать базы данных SQLite и PostgreSQL\n","\n","# в данном случае имя файла базы данных SQLite - record_manager_cache.sql\n","\n","# Импортируем модуль asyncio для работы с асинхронным кодом и управления циклом событий\n","import asyncio\n","\n","# Импортируем путь к базе данных SQLite из модуля с константами нашего приложения\n","from constants import RECORD_MANAGER\n","\n","# Импортируем класс SQLRecordManager из LangChain для управления индексами документов\n","from langchain_classic.indexes import SQLRecordManager\n","\n","# Импортируем функцию для подключения к БД и создания таблиц. Она определена в файле dependencies.py\n","from dependencies import connect_and_create_db\n","\n","# Инициализируем менеджер записей, настраивая его параметры для работы с базой данных\n","record_manager = SQLRecordManager(\n","    # Указываем уникальный префикс (пространство имен) для изоляции записей этого проекта\n","    namespace=\"Stardew\",\n","    # Передаем строку подключения к нашей локальной базе данных SQLite из константы\n","    db_url=RECORD_MANAGER,\n","    # Включаем асинхронный режим работы для бесконфликтного выполнения внутри асинхронного API\n","    async_mode=True\n",")\n","\n","# Объявляем главную асинхронную функцию, которая будет выполнять инициализацию базы SQLite\n","async def main_SQLite_init():\n","    # Асинхронно создаем таблицы и схему данных в SQLite, если они еще не созданы\n","    await record_manager.acreate_schema()\n","\n","# Главная асинхронная функция для инициализации PostgreSQL таблицы\n","async def main_pg_init():\n","    print(\"Попытка подключения к PostgreSQL и создания таблицы...\")\n","    await connect_and_create_db()\n","    print(\"Процесс инициализации PostgreSQL завершен.\")\n","\n","# Проверяем, что скрипт запущен напрямую пользователем, а не импортирован как модуль\n","if __name__ == \"__main__\":\n","  asyncio.run(main_SQLite_init())\n","  asyncio.run(main_pg_init())"],"metadata":{"id":"UfeOUeX721ml","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778837368783,"user_tz":-420,"elapsed":50,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"ebffd615-f82f-44a4-c943-3233109dad4e"},"execution_count":18,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing db_main.py\n"]}]},{"cell_type":"code","metadata":{"id":"d1737e84"},"source":["!python db_main.py"],"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["### Вопрос:\n","\n","Создание баз данных SQLite и PostgreSQL происходит при запуске файла db_main.py нужно ли в этом файле прописать создание базы данных Chroma или она буден создана при первом вызове chroma - Подключение к Chroma\n","\n","**Ответ на вопрос:**\n","\n","Нам не нужно явно прописывать создание базы данных Chroma в файле `db_main.py`.\n","\n","ChromaDB является файловой векторной базой данных. Когда вы инициализируете её, указывая `persist_directory` (как это сделано в `constants.py` и `dependencies.py`), она автоматически создает необходимые файлы и структуры в этой директории, если они ещё не существуют, или загружает существующую базу данных при первом обращении.\n","Это происходит при импорте `dependencies.py` и инициализации объекта `AsyncChroma`.\n","\n","Таким образом, нет необходимости добавлять отдельный вызов для создания схемы Chroma в `db_main.py`, в отличие от SQLite и PostgreSQL, которые требуют явной инициализации схемы таблиц."],"metadata":{"id":"-EnMFBl2w6qN"}},{"cell_type":"markdown","source":["### Посмотреть структуру таблиц SQLite"],"metadata":{"id":"QgCh7hQKyX89"}},{"cell_type":"code","source":["# Путь к созданному файлу базы данных на вашем Google Диске\n","db_path = '/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/data/db_file/record_manager_cache.sql'\n","\n","# Подключаемся к базе данных\n","conn = sqlite3.connect(db_path)\n","cursor = conn.cursor()\n","\n","# Получаем список всех таблиц и их SQL-структуру (схему)\n","cursor.execute(\"SELECT name, sql FROM sqlite_master WHERE type='table';\")\n","tables = cursor.fetchall()\n","\n","# Выводим результат на экран\n","for name, sql in tables:\n","    print(f\"Таблица: {name}\")\n","    print(f\"Схема создания:\\n{sql}\\n\" + \"-\"*50)\n","\n","# Закрываем соединение\n","conn.close()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"dxuAOJvq5cT7","executionInfo":{"status":"ok","timestamp":1778403658642,"user_tz":-420,"elapsed":407,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"c9d99b41-5092-4ea3-fd76-287f7a92d230"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Таблица: upsertion_record\n","Схема создания:\n","CREATE TABLE upsertion_record (\n","\tuuid VARCHAR NOT NULL, \n","\t\"key\" VARCHAR, \n","\tnamespace VARCHAR NOT NULL, \n","\tgroup_id VARCHAR, \n","\tupdated_at FLOAT, \n","\tPRIMARY KEY (uuid), \n","\tCONSTRAINT uix_key_namespace UNIQUE (\"key\", namespace)\n",")\n","--------------------------------------------------\n"]}]},{"cell_type":"markdown","metadata":{"id":"ea82fd61"},"source":["### 🛠 Инструкция по подключению к PostgreSQL через DBViewer\n","\n","Для подключения к созданной базе данных PostgreSQL через любой DBViewer (например, DBeaver, pgAdmin, DataGrip) нам понадобятся следующие параметры:\n","\n","*   **Host (Хост):** `localhost` (если вы запускаете PostgreSQL локально, или IP-адрес сервера, где он развернут)\n","*   **Port (Порт):** `5432`\n","*   **Database (Имя базы данных):** `bpmn_models`\n","*   **User (Пользователь):** `Analyst`\n","*   **Password (Пароль):** Это значение хранится в `userdata.get('POSTGRES_PASSWORD')` или по умолчанию `12345678`. Используйте тот пароль, который вы установили в секретах Google Colab или по умолчанию.\n","\n","\n","### Пример подключения в DBeaver:\n","\n","1.  Откройте DBeaver.\n","2.  Нажмите `File` -> `New` -> `Database Connection`.\n","3.  Выберите `PostgreSQL` и нажмите `Next`.\n","4.  На вкладке `Main` введите:\n","    *   **Host:** `localhost` (или IP вашего сервера)\n","    *   **Port:** `5432`\n","    *   **Database:** `bpmn_models`\n","    *   **Username:** `Analyst`\n","    *   **Password:** Ваш пароль\n","5.  (Необязательно) Нажмите `Test Connection...`, чтобы убедиться, что все параметры верны.\n","6.  Нажмите `Finish`.\n","\n","После успешного подключения мы сможем просмотреть таблицы, в частности `xml_documents`, которая должна быть создана."]},{"cell_type":"markdown","source":["## Инициализации для работы с Chroma LLM record_manager(SQLite) PostgreSQL"],"metadata":{"id":"JX5fFtMro3aq"}},{"cell_type":"code","source":["# Переходим в папку Проекта\n","%cd {app_path}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778838814555,"user_tz":-420,"elapsed":31,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"7517ed2c-4741-41b5-b300-5682ef118553","id":"_j4MkLmjr5fr"},"execution_count":19,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app\n"]}]},{"cell_type":"code","source":["%%writefile dependencies.py\n","\n","from uuid import UUID\n","import datetime\n","\n","from chroma_async import AsyncChroma\n","from databases import Database\n","from sqlalchemy.dialects import postgresql\n","from sqlalchemy import (\n","    create_engine,\n","    MetaData,\n","    Table,\n","    Column,\n","    String,\n","    DateTime,\n","    Text,\n",")\n","from sqlalchemy.dialects.postgresql import UUID as PG_UUID\n","\n","from constants import (\n","    CHROMA_COLLECTION,\n","    CHROMA_PATH,\n","    EMBEDDINGS_MODEL,\n","    LLM_MODEL,\n","    RECORD_MANAGER,\n","    POSTGRES_CONNECTION_ASYNC_URL,\n","    POSTGRES_CONNECTION_SYNC_URL,\n","\n",")\n","from schemas.db_models import XMLDocument\n","\n","from langchain_classic.indexes import SQLRecordManager\n","from langchain_ollama import ChatOllama, OllamaEmbeddings\n","\n","# Инициализация эмбеддингов\n","embedding_model = OllamaEmbeddings(model=EMBEDDINGS_MODEL)\n","\n","# Подключение к Chroma\n","chroma = AsyncChroma(\n","    collection_name=CHROMA_COLLECTION,\n","    persist_directory=CHROMA_PATH,\n","    embedding_function=embedding_model,\n",")\n","\n","# Инициализация менеджера записей для отслеживания состояния документов\n","record_manager = SQLRecordManager(\n","    namespace=\"Stardew\", db_url=RECORD_MANAGER, async_mode=True\n",")\n","\n","# Инициализация LLM\n","llm = ChatOllama(model=LLM_MODEL)\n","\n","# Инициализация PostgreSQL базы данных\n","database = Database(POSTGRES_CONNECTION_ASYNC_URL)  # Создаёт объект базы данных с использованием асинхронной библиотеки (например, databases), передавая строку подключения к PostgreSQL\n","metadata = MetaData()  # Инициализирует объект MetaData — контейнер для описания структуры таблиц и схемы БД в SQLAlchemy\n","\n","\n","# Определение таблицы для XML документов\n","xml_documents_table = Table(  # Создаёт описание таблицы в памяти (не в БД) с помощью класса Table из SQLAlchemy\n","    \"xml_documents\",  # Имя таблицы в базе данных\n","    metadata,  # Ссылка на объект MetaData, к которому привязывается таблица\n","    Column(\"id\", PG_UUID(as_uuid=True), primary_key=True, default=UUID),  # Колонка id: UUID как первичный ключ; as_uuid=True сохраняет тип UUID Python; default=UUID задаёт генерацию UUID по умолчанию\n","    Column(\"parent_doc_id\", String, index=True, nullable=False),  # Колонка parent_doc_id: строковый тип, с индексом для быстрого поиска, обязательное поле (не может быть NULL)\n","    Column(\"filename\", String, nullable=False),  # Колонка filename: строковый тип, обязательное поле\n","    Column(\"xml_content\", Text, nullable=False),  # Колонка xml_content: тип Text для хранения больших текстовых данных (XML), обязательное поле\n","    Column(\"upload_timestamp\", DateTime, default=datetime.datetime.utcnow),  # Колонка upload_timestamp: тип DateTime для даты и времени загрузки; default=datetime.datetime.utcnow автоматически устанавливает текущее время UTC при создании записи\n",")\n","\n","# Определение таблицы для результатов генерации LLM\n","generated_results_table = Table(\n","    \"generated_results\",\n","    metadata,\n","    Column(\"id\", PG_UUID(as_uuid=True), primary_key=True, default=UUID),\n","    Column(\"parent_doc_id\", String, index=True),\n","    Column(\"result_type\", String),\n","    Column(\"content\", Text),\n","    Column(\"created_at\", DateTime, default=datetime.datetime.utcnow),\n",")\n","\n","async def connect_and_create_db():\n","    \"\"\"Подключается к базе данных и создаёт таблицу XML документов, если её нет.\"\"\"\n","    await database.connect()  # Асинхронно подключается к БД через объект database (использует асинхронный драйвер, например asyncpg)\n","    # URL для create_engine должен быть синхронным. Заменяем '+asyncpg' на синхронный драйвер, например '+psycopg2'\n","    engine = create_engine(POSTGRES_CONNECTION_SYNC_URL)  # Создаёт движок SQLAlchemy для синхронного взаимодействия с БД (нужен для операций с метаданными)\n","    metadata.create_all(engine)  # Выполняет SQL‑запросы для создания всех таблиц, описанных в metadata, в БД через движок engine; если таблица уже есть — ничего не делает\n","    print(\"Таблица PostgreSQL 'xml_documents' и 'generated_results' созданы или уже существуют.\")  # Выводит сообщение о результате операции\n","\n","async def disconnect_db():\n","    \"\"\"Отключается от базы данных.\"\"\"\n","    await database.disconnect()  # Асинхронно разрывает соединение с БД через объект database\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jJIhl067pMd5","executionInfo":{"status":"ok","timestamp":1778838820052,"user_tz":-420,"elapsed":82,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"af60984d-788b-40c3-e974-899cb78efff3"},"execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing dependencies.py\n"]}]},{"cell_type":"markdown","source":["# Шаг 1: загрузка документов в базу данных\n","\n","без пользовательского интерфейса"],"metadata":{"id":"pnoPBNsdp_Q5"}},{"cell_type":"markdown","source":["## Создадим схему\n","для единого формата сохранения документов с указанием содержимого (content) и метаданных документа.\n","\n","Метаданные являются необязательными."],"metadata":{"id":"O0xgrZJU-A7S"}},{"cell_type":"code","source":["# Переходим в папку schemas внутри app\n","%cd {app_path}/schemas"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"nE0Hen2QCMsc","executionInfo":{"status":"ok","timestamp":1778838849164,"user_tz":-420,"elapsed":73,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"7acd6954-1188-4634-9464-06118ac87e2e"},"execution_count":21,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app/schemas\n"]}]},{"cell_type":"code","source":["%%writefile __init__.py"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XfkM3S9FDJym","executionInfo":{"status":"ok","timestamp":1778838852974,"user_tz":-420,"elapsed":15,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"d0c86bf1-cd38-4ba9-f9a6-6c56e4032a57"},"execution_count":22,"outputs":[{"output_type":"stream","name":"stdout","text":["Overwriting __init__.py\n"]}]},{"cell_type":"code","source":["%%writefile document_upload.py\n","\n","from pydantic import BaseModel, Field\n","\n","\n","class DocumentUpload(BaseModel):\n","    content: str\n","    metadata: dict | None = Field(default=None)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"OsGz_tAz-N_j","executionInfo":{"status":"ok","timestamp":1778838964804,"user_tz":-420,"elapsed":36,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"29ba8a56-de85-418e-de05-cb0be67f972b"},"execution_count":23,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing document_upload.py\n"]}]},{"cell_type":"code","source":["# Переходим в папку Проекта\n","%cd {app_path}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"4nrV4SAqNjxc","executionInfo":{"status":"ok","timestamp":1778838986977,"user_tz":-420,"elapsed":10,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"6c2bae08-6c7f-4216-98e7-726545f23a4d"},"execution_count":24,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app\n"]}]},{"cell_type":"markdown","source":["## Создаём API\n","в директории `routers` создать файл `document_loader.py`, в котором пропишем сам API."],"metadata":{"id":"ujkGyiS0UjVt"}},{"cell_type":"code","source":["# Переходим в папку routers внутри app\n","%cd {app_path}/routers"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"GZwNyCTiWoBY","executionInfo":{"status":"ok","timestamp":1778838992366,"user_tz":-420,"elapsed":9,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"f1cce73d-e846-48d1-958b-82edb9874bf1"},"execution_count":25,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app/routers\n"]}]},{"cell_type":"code","metadata":{"id":"2dd8e9b3","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839013240,"user_tz":-420,"elapsed":66,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"17b43d62-da98-4047-cde7-0064914b2fb8"},"source":["%%writefile document_loader.py\n","\n","import hashlib  # Импортируем стандартную библиотеку для генерации хэшей\n","import os       # Импортируем для работы с путями к файлам\n","import io       # Импортируем для работы с бинарными потоками файлов\n","\n","from dependencies import chroma, record_manager, database, xml_documents_table # Импортируем database и xml_documents_table\n","from schemas.document_upload import DocumentUpload # Схема для загрузки документа в виде JSON\n","from schemas.db_models import XMLDocument # Импортируем Pydantic-схему для XMLDocument\n","\n","from fastapi import APIRouter, Body, Query, UploadFile, File, HTTPException, status # Добавляем UploadFile, File, HTTPException, status\n","\n","from langchain_core.indexing import aindex\n","from langchain_text_splitters import RecursiveCharacterTextSplitter\n","from langchain_core.documents import Document\n","\n","# Импорты для обработки файлов\n","from langchain_community.document_loaders import PyPDFLoader # Для PDF\n","import docx # Для DOCX\n","\n","\n","router = APIRouter()\n","\n","# Инициализация разделителя текста на чанки\n","text_splitter = RecursiveCharacterTextSplitter(\n","    chunk_size=1500,\n","    chunk_overlap=150,\n","    length_function=len,\n","    is_separator_regex=False,\n","    separators=[\"\\n\", \"\\n\\n\", \".\"],\n",")\n","\n","# Эндпоинт для загрузки документа в виде JSON-объекта\n","@router.post(\n","    \"/load/doc_as_json\",\n","    description=\"Загрузка документа - в виде JSON-объекта - с детерминированным ID для защиты от дубликатов\"\n",")\n","async def upload_document(document_input: DocumentUpload = Body()):\n","    # 1. Генерируем стабильный parent_doc_id на основе хэша текста (SHA-256)\n","    # Для одного и того же текста этот ID всегда будет одинаковым\n","    text_hash = hashlib.sha256(document_input.content.encode(\"utf-8\")).hexdigest()\n","    parent_id = text_hash\n","\n","    # 2. Формируем метаданные, которые будут уникальны для этого контента\n","    final_metadata = document_input.metadata.copy() if document_input.metadata else {}\n","    final_metadata[\"parent_doc_id\"] = parent_id\n","\n","    # 3. Нарезаем текст на чанки\n","    chunks: list[Document] = text_splitter.create_documents(\n","        texts=[document_input.content],\n","        metadatas=[final_metadata]\n","    )\n","\n","    # 4. Передаем данные в aindex. Теперь при повторном запросе хэши чанков сойдутся,\n","    # и record_manager заблокирует дублирование в Chroma\n","    out = await aindex(\n","        chunks,\n","        record_manager=record_manager,\n","        vector_store=chroma\n","    )\n","\n","    return {\n","        \"index_status\": out,\n","        \"parent_doc_id\": parent_id\n","    }\n","\n","# Эндпоинт для получения списка всех чанков\n","@router.get(\n","    \"/get/documents\",\n","    description=\"Получить список всех чанков и их метаданных, записанных в Chroma\"\n",")\n","async def get_stored_documents(\n","    parent_doc_id: str | None = Query(default=None, description=\"Фильтр по ID родительского документа\"),\n","    limit: int = Query(default=10, description=\"Количество выводимых чанков\")\n","):\n","    try:\n","        # 1. Формируем фильтр, если клиент передал parent_doc_id\n","        where_filter = {\"parent_doc_id\": parent_doc_id} if parent_doc_id else None\n","\n","        # 2. Делаем прямой запрос к коллекции Chroma через метод .get()\n","        # Извлекаем тексты (documents) и метаданные (metadatas)\n","        result = chroma.get(\n","            where=where_filter,\n","            limit=limit,\n","            include=[\"documents\", \"metadatas\"]  # Можно добавить \"embeddings\", если нужны сами векторы-числа\n","        )\n","\n","        # 3. Форматируем ответ для удобного чтения на фронтенде или в Swagger\n","        formatted_chunks = []\n","        if result and \"documents\" in result:\n","            for idx in range(len(result[\"ids\"])):\n","                formatted_chunks.append({\n","                    \"chunk_id\": result[\"ids\"][idx],\n","                    \"text\": result[\"documents\"][idx],\n","                    \"metadata\": result[\"metadatas\"][idx] if result[\"metadatas\"] else {}\n","                })\n","\n","        return {\n","            \"total_fetched\": len(formatted_chunks),\n","            \"chunks\": formatted_chunks\n","        }\n","\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=f\"Ошибка чтения из Chroma: {str(e)}\")\n","\n","\n","# Вспомогательная функция для чтения содержимого файла в зависимости от его типа\n","async def _read_document_content(file: UploadFile) -> str:\n","    \"\"\"Вспомогательная функция для чтения содержимого файла в зависимости от его типа.\n","    Поддерживает .txt, .pdf, .docx.\"\"\"\n","    content = \"\"\n","    # Определяем расширение файла по его имени\n","    file_extension = os.path.splitext(file.filename)[1].lower()\n","\n","    if file_extension == \".txt\":\n","        # Для текстовых файлов просто читаем содержимое\n","        content = (await file.read()).decode(\"utf-8\")\n","    elif file_extension == \".pdf\":\n","        # Для PDF используем PyPDFLoader из LangChain\n","        # PyPDFLoader требует путь к файлу, поэтому сохраним его временно\n","        temp_pdf_path = f\"/tmp/{file.filename}\"\n","        with open(temp_pdf_path, \"wb\") as buffer:\n","            buffer.write(await file.read())\n","        loader = PyPDFLoader(temp_pdf_path)\n","        pages = loader.load()\n","        # Объединяем содержимое всех страниц\n","        content = \"\\n\".join([p.page_content for p in pages])\n","        os.remove(temp_pdf_path) # Удаляем временный файл\n","    elif file_extension == \".docx\":\n","        # Для DOCX используем python-docx, читая из байтового потока\n","        doc = docx.Document(io.BytesIO(await file.read()))\n","        # Извлекаем текст из каждого параграфа\n","        content = \"\\n\".join([para.text for para in doc.paragraphs])\n","    else:\n","        raise HTTPException(\n","            status_code=status.HTTP_400_BAD_REQUEST,\n","            detail=f\"Неподдерживаемый формат файла: {file_extension}. Поддерживаются .txt, .pdf, .docx.\"\n","        )\n","    return content\n","\n","\n","@router.post(\n","    \"/load/doc_as_file_and_xml\",\n","    description=\"\"\"Загрузка основного документа (TXT, PDF, DOCX) и связанного с ним XML файла.\n","                 Основной документ индексируется в Chroma, XML сохраняется в PostgreSQL.\"\"\"\n",")\n","async def upload_file_and_xml(\n","    document_file: UploadFile = File(..., description=\"Основной документ (TXT, PDF, DOCX)\"),\n","    xml_file: UploadFile = File(..., description=\"Связанный XML-файл\")\n","):\n","    try:\n","        # 1. Читаем содержимое основного документа\n","        main_doc_content = await _read_document_content(document_file)\n","        if not main_doc_content:\n","            raise HTTPException(\n","                status_code=status.HTTP_400_BAD_REQUEST,\n","                detail=\"Основной документ пуст или не удалось прочитать.\"\n","            )\n","\n","        # 2. Генерируем стабильный parent_doc_id на основе хэша основного документа\n","        parent_id = hashlib.sha256(main_doc_content.encode(\"utf-8\")).hexdigest()\n","\n","        # 3. Читаем содержимое XML файла\n","        xml_content = (await xml_file.read()).decode(\"utf-8\")\n","        if not xml_content:\n","            raise HTTPException(\n","                status_code=status.HTTP_400_BAD_REQUEST,\n","                detail=\"XML-файл пуст или не удалось прочитать.\"\n","            )\n","\n","        # 4. Сохраняем XML документ в PostgreSQL\n","        xml_doc_data = XMLDocument(\n","            parent_doc_id=parent_id,\n","            filename=xml_file.filename,\n","            xml_content=xml_content\n","        )\n","        query = xml_documents_table.insert().values(**xml_doc_data.model_dump())\n","        await database.execute(query)\n","        print(f\"XML-документ '{xml_file.filename}' сохранен в PostgreSQL с parent_doc_id: {parent_id}\")\n","\n","        # 5. Формируем метаданные для чанков основного документа\n","        final_metadata = {\n","            \"parent_doc_id\": parent_id,\n","            \"original_filename\": document_file.filename,\n","            \"xml_filename\": xml_file.filename\n","        }\n","\n","        # 6. Нарезаем основной документ на чанки и индексируем их в Chroma\n","        chunks: list[Document] = text_splitter.create_documents(\n","            texts=[main_doc_content],\n","            metadatas=[final_metadata]\n","        )\n","\n","        out = await aindex(\n","            chunks,\n","            record_manager=record_manager,\n","            vector_store=chroma\n","        )\n","        print(f\"Основной документ '{document_file.filename}' проиндексирован в Chroma с parent_doc_id: {parent_id}\")\n","\n","        return {\n","            \"index_status\": out,\n","            \"parent_doc_id\": parent_id,\n","            \"message\": \"Документ и XML успешно загружены и проиндексированы.\"\n","        }\n","\n","    except HTTPException as e:\n","        # Перехватываем и повторно выбрасываем HTTPException для корректной обработки FastAPI\n","        raise e\n","    except Exception as e:\n","        # Обрабатываем другие непредвиденные ошибки\n","        print(f\"Ошибка при загрузке файла и XML: {e}\")\n","        raise HTTPException(status_code=status.HTTP_500_INTERNAL_SERVER_ERROR, detail=f\"Внутренняя ошибка сервера: {str(e)}\")"],"execution_count":26,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing document_loader.py\n"]}]},{"cell_type":"markdown","metadata":{"id":"7221db32"},"source":["### 🛠 Инструкция по выбору `chunk_size` для RAG\n","\n","Параметр `chunk_size` определяет, на какие фрагменты (токены или символы) будет разбит ваш документ перед попаданием в векторную базу.\n","\n","#### 1. Критерии выбора:\n","*   **Маленькие чанки (100–300 символов):**\n","    *   *Плюсы:* Высокая точность поиска (Retrieval). Модель получает только самый релевантный кусок.\n","    *   *Минусы:* Потеря контекста. Если ответ размазан по абзацу, модель его не соберет.\n","*   **Средние чанки (500–1000 символов) — Рекомендуемо:**\n","    *   Золотая середина для большинства бизнес-документов и инструкций.\n","*   **Большие чанки (2000+ символов):**\n","    *   *Плюсы:* Сохранение структуры документа и сложных логических связей.\n","    *   *Минусы:* Шум. Модель может отвлечься на посторонние детали в чанке.\n","\n","#### 2. Зависимость от LLM:\n","*   Если у модели маленькое контекстное окно (например, старые версии GPT), используйте чанки меньше.\n","*   Для современных моделей (Gemma 3, Claude 3.5) с большими окнами можно смело увеличивать размер до 1000-1500.\n","\n","#### 3. Параметр `chunk_overlap`:\n","Всегда оставляйте **10-20%** от размера чанка для перекрытия (`overlap`). Это гарантирует, что важная мысль не будет разрезана пополам на стыке двух чанков."]},{"cell_type":"code","source":["# Переходим в папку Проекта\n","%cd {app_path}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839041232,"user_tz":-420,"elapsed":37,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"437d81de-165f-4855-f739-2a54e3ef22aa","id":"29tDxBUdWynj"},"execution_count":27,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app\n"]}]},{"cell_type":"markdown","source":["### Тест API"],"metadata":{"id":"hrArLxK2gCGc"}},{"cell_type":"code","metadata":{"id":"90ab0637","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839045998,"user_tz":-420,"elapsed":54,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"ff48a533-6869-4376-c5b8-ff48caf53639"},"source":["%%writefile test_api_document_loader.py\n","\n","from fastapi import FastAPI, UploadFile, File # Добавляем UploadFile, File\n","from routers.document_loader import router  # Импорт роутера из файла\n","\n","app = FastAPI(title=\"Загрузка документов для RAG\")\n","\n","# Подключаем роутер\n","app.include_router(router)\n","\n","# Пример использования нового эндпоинта (требует клиента для загрузки файлов, например Postman/Insomnia/curl)\n","# from httpx import AsyncClient\n","# async def test_upload_file_and_xml():\n","#     async with AsyncClient(app=app, base_url=\"http://test\") as ac:\n","#         with open(\"example.txt\", \"rb\") as doc_file, open(\"example.xml\", \"rb\") as xml_file:\n","#             response = await ac.post(\n","#                 \"/load/file_and_xml\",\n","#                 files={\"document_file\": (\"example.txt\", doc_file, \"text/plain\"),\n","#                        \"xml_file\": (\"example.xml\", xml_file, \"application/xml\")}\n","#             )\n","#             assert response.status_code == 200\n","#             print(response.json())\n"],"execution_count":28,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing test_api_document_loader.py\n"]}]},{"cell_type":"markdown","metadata":{"id":"454c1c67"},"source":["### 🛠 Инструкция по проверке функционала `document_loader.py`\n","\n","После запуска сервера (`!uvicorn test_api_document_loader:app`) вы можете проверить загрузку документов следующими способами:\n","\n","#### 1. Через Swagger UI (рекомендуется)\n","1. Перейдите по адресу вашего сервера (обычно `http://127.0.0.1:8000/docs`).\n","2. Найдите эндпоинт `POST /load/doc_as_file_and_xml`.\n","3. Нажмите **Try it out**.\n","4. Выберите основной файл (PDF, DOCX или TXT) и соответствующий ему XML.\n","5. Нажмите **Execute**. В ответе вы должны увидеть `parent_doc_id`.\n","\n","#### 2. Проверка через curl (в терминале)\n","```bash\n","curl -X 'POST' \\\n","  'http://127.0.0.1:8000/load/doc_as_file_and_xml' \\\n","  -H 'accept: application/json' \\\n","  -H 'Content-Type: multipart/form-data' \\\n","  -F 'document_file=@your_doc.pdf;type=application/pdf' \\\n","  -F 'xml_file=@your_model.xml;type=application/xml'\n","```\n","\n","#### 3. Верификация результата\n","Чтобы убедиться, что данные действительно сохранились:\n","1. **В Chroma:** Вызовите `GET /get/documents?parent_doc_id=ВАШ_ID`. Вы должны увидеть список созданных чанков.\n","2. **В PostgreSQL:** Подключитесь через DBeaver и выполните:\n","   `SELECT * FROM xml_documents WHERE parent_doc_id = 'ВАШ_ID'`;\n","   Там должен появиться контент вашего XML-файла.\n","\n","#### 4. Проверка дубликатов\n","Попробуйте загрузить тот же файл еще раз. Благодаря `record_manager` и детерминированному хэшированию, в ответе `index_status` должно быть указано `num_added: 0`, так как чанки с таким хэшем уже существуют."]},{"cell_type":"markdown","source":["# Шаг 2: бизнес-логика - RAG по всем документам"],"metadata":{"id":"WEu7uC7aaUMK"}},{"cell_type":"markdown","source":["## Схема запроса пользователя\n","\n","чтобы стандартизировать формат ввода запросов от клиента, создадим схему, по которой будет строиться Request Body в файле `search_query.py`.\n","\n","Клиент может как задавать вопрос, так и добавлять уточняющие метаданные для поиска."],"metadata":{"id":"dls3c2tig2yh"}},{"cell_type":"code","source":["# Переходим в папку schemas внутри app\n","%cd {app_path}/schemas"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839246380,"user_tz":-420,"elapsed":61,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"f5f5cb01-e586-45d1-f219-e1707010214f","id":"bS9snrM6hlGR"},"execution_count":29,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app/schemas\n"]}]},{"cell_type":"code","source":["%%writefile search_query.py\n","\n","from pydantic import BaseModel, Field\n","\n","\n","class SearchQuery(BaseModel):\n","    content: str\n","    metadata: dict | None = Field(default=None)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839249418,"user_tz":-420,"elapsed":47,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"44f6af55-ac72-4d2a-88f7-7c24719f9a12","id":"Xu3hXWyfhlGS"},"execution_count":30,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing search_query.py\n"]}]},{"cell_type":"code","source":["# Переходим в папку Проекта\n","%cd {app_path}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839298099,"user_tz":-420,"elapsed":63,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"28a9751f-fbfc-4f2d-b8bd-90d7c226ac3e","id":"zO4vHxPFhlGT"},"execution_count":31,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app\n"]}]},{"cell_type":"markdown","source":["## Системный промт\n","\n","Так как мы работаем с RAG, то ему очень желательно прописать инструкцию \"поведения\", т.е. системный промпт (system).\n","\n","Пример такого промпта может указать в папке `prompts` в файле `*.py`.\n","\n","Обратите внимание, что он работает как шаблон, и в фигурных скобках указываем ключевое слово `context`, чтобы найденные данные были подставлены в это место шаблона."],"metadata":{"id":"BiMcJZX2j3Eh"}},{"cell_type":"code","source":["# Переходим в папку prompts внутри app\n","%cd {app_path}/prompts"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839377858,"user_tz":-420,"elapsed":51,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"2dbba3e7-1dca-47a0-a755-fa7fb444a389","id":"0mGJu48dmVzn"},"execution_count":32,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app/prompts\n"]}]},{"cell_type":"code","source":["%%writefile __init__.py"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839379454,"user_tz":-420,"elapsed":34,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"664209c6-b637-4aac-ca60-f2d49e055e61","id":"snHEnQu4mmjH"},"execution_count":33,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing __init__.py\n"]}]},{"cell_type":"markdown","source":["### генерации XML BPMN 2.0"],"metadata":{"id":"Vug-xF4C1MKP"}},{"cell_type":"markdown","metadata":{"id":"52d6614d"},"source":["#### Инструкция по составлению промпта для BPMN XML\n","\n","Чтобы LLM генерировала валидный BPMN 2.0 XML, который можно открыть в Camunda или Modelio, придерживайтесь следующих правил:\n","\n","1.  **Ролевая модель:** Укажите, что модель — эксперт в нотации BPMN 2.0.\n","2.  **Формат вывода:** Явно потребуйте возвращать **только** XML-код, без Markdown-разметки (без ```xml ... ```) и без вводных фраз.\n","3.  **Структура:** Напомните о необходимости корневого элемента `<bpmn:definitions>` и пространств имен (xmlns:bpmn, xmlns:bpmndi).\n","4.  **Контекст:** Инструктируйте модель использовать данные из `{context}` для именования процессов (`bpmn:process`), задач (`bpmn:userTask`, `bpmn:serviceTask`) и шлюзов (`bpmn:exclusiveGateway`).\n","\n","#### Пример структуры промпта:\n","*   *\"Сгенерируй BPMN 2.0 XML на основе предоставленного описания процесса. Используй стандартную схему. Все названия элементов должны быть на русском языке. Результат должен содержать только чистый XML.\"*"]},{"cell_type":"code","metadata":{"id":"f4029666","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839383762,"user_tz":-420,"elapsed":56,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"94d0a6bc-42a0-467e-b92b-6fd9068d6b40"},"source":["%%writefile bpmn_xml_rules.py\n","\n","template = \"\"\"Ты — эксперт по нотации BPMN 2.0. Твоя задача — преобразовать текстовое описание процесса в валидный файл BPMN XML.\n","### ПРАВИЛА:\n","1. Используй только предоставленный контекст: {context}\n","2. Вывод должен быть ТОЛЬКО в формате XML. Не пиши никаких пояснений до или после кода.\n","3. Обязательно включи секцию BPMNDiagram для визуального отображения (хотя бы с базовыми координатами).\n","4. Названия задач и событий бери из описания пользователя.\n","5. Если в контексте недостаточно данных для полной схемы, создай минимально жизнеспособный процесс (Start -> Task -> End).\n","6. Все названия элементов должны быть на русском языке.\n","\n","### ПРАВИЛА BPMN:\n","1. Используйте символы и надписи, чтобы процессную логику можно было понять из напечатанной диаграммы.\n","2. Сделайте модель иерархической, поместив каждый уровень процесса на отдельную страницу.\n","3. Используйте пул «черный ящик» для изображения клиента, другого внешнего потребителя или поставщика.\n","4. Начинайте процесс, взаимодействующий с внешним потребителем, начальным событием-сообщением, получающим поток сообщений из пула «черный ящик».\n","5. Моделируйте внутренние подразделения организации дорожками в рамках одного процессного пула, а не отдельными пулами. Отдельные пулы изображают независимые процессы.\n","6. Подписывайте процессный пул названием процесса, а пул «черный ящик» — названием внешней сущности.\n","7. Обозначьте успешные конечные состояния процесса (подпроцесса) и отклонения отдельными конечными событиями и маркируйте их названиями конечных состояний.\n","8. Называйте действия по шаблону «глагол — существительное».\n","9. В процессе верхнего уровня задайте тип начального события, чтобы показать, как он запускается.\n","Если процесс запускается внешним запросом, используйте начальное событие-сообщение. Событие должно называться Получить [название потока сообщений].\n","Если процесс запускается по расписанию, используйте начальное событие-таймер. Надпись на событии должна конкретизировать расписание, например, ежемесячно или по понедельникам в 8:00.\n","Если процесс запускается исполнителем вручную, используйте простое начальное событие. Надписывать его не обязательно.\n","10. Если за подпроцессом следует развилка, надписанная с вопросительным знаком, то у подпроцесса должно быть несколько конечных событий\n","и название одного из них должно совпадать с названием развилки.\n","11. Для каждого события-сообщения покажите поток сообщений.\n","12. Поддерживайте соответствие потоков сообщений на родительской и дочерних диаграммах.\n","13. Надписывайте поток сообщений названием сообщения.\n","14. Два конечных события на одной диаграмме не должны называться одинаково.\n","15. Два действия в одной модели не должны называться одинаково.\n","16. У подпроцесса должно быть одно простое начальное событие.\n","17. Процессный пул на дочерней диаграмме (если он изображен) должен быть подписан названием процесса верхнего уровня, а не названием подпроцесса.\n","18. В иерархической модели дочерняя диаграмма не должна содержать процессы верхнего уровня.\n","19. Не используйте для слияния альтернативных маршрутов развилку «или/или», если следующий по потоку элемент не есть развилка. Просто соедините потоки управления со следующим элементом.\n","20. Не используйте развилку «и» для слияния параллельных маршрутов перед простым конечным событием. Простое конечное событие подразумевает слияние. (если схема НЕ исполняема)\n","21. Поток управления не может пересекать границы пула (процесса).\n","22. Поток управления не может пересекать границы подпроцесса.\n","23. Поток сообщений не может соединять элементы внутри одного пула.\n","24. Поток управления может соединять только действия, развилки и события, причем оба конца потока управления должны быть соединены с каким-то из этих элементов.\n","25. Поток сообщений может соединяться только с действием, событием-сообщением (или множественным событием) или границей пула «черный ящик»,\n","причем оба конца потока сообщений должны быть соединены с каким-то из этих элементов.\n","\n","### ОПИСАНИЕ ПРОЦЕССА:\n","{input}\"\"\""],"execution_count":34,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing bpmn_xml_rules.py\n"]}]},{"cell_type":"markdown","metadata":{"id":"c52e0e96"},"source":["#### Что такое `input` и как он задаётся?\n","\n","В контексте нашего RAG-сервиса, `input` — это динамическая переменная в шаблоне промпта (`ChatPromptTemplate`), которая содержит **исходный текст запроса пользователя**.\n","\n","#### 1. Откуда приходят данные?\n","Когда мы отправляем POST-запрос на эндпоинт `/search/rag`:\n","```json\n","{\n","  \"content\": \"Опиши процесс закупки товара для формирования XML\",\n","  \"metadata\": {}\n","}\n","```\n","Значение `\"content\"` попадает в переменную `search_query.content` внутри функции `rag()` в файле `rag.py`.\n","\n","#### 2. Как данные попадают в промпт?\n","В файле `rag.py` есть строка вызова модели:\n","```python\n","response = await chain.ainvoke({\n","    \"context\": context_text,\n","    \"input\": search_query.content  # Вот здесь мы связываем ввод пользователя с переменной {input}\n","})\n","```\n","\n","#### 3. Итоговый вид для LLM\n","Если в `bpmn_xml_rules.py` промпт заканчивается так:\n","```text\n","### ОПИСАНИЕ ПРОЦЕССА:\n","{input}\n","```\n","То модель увидит:\n","```text\n","### ОПИСАНИЕ ПРОЦЕССА:\n","Опиши процесс закупки товара для формирования XML\n","```"]},{"cell_type":"markdown","metadata":{"id":"94549ed1"},"source":["#### Что такое `context` и как он формируется?\n","\n","Переменная `context` в промпте — это собранные воедино данные, которые помогают LLM дать точный ответ, основываясь на вашей базе знаний, а не на общих знаниях модели.\n","\n","#### 1. Из чего состоит context?\n","В коде `rag.py` контекст собирается из двух источников:\n","*   **ChromaDB:** Топ-3 самых похожих фрагмента текста на запрос пользователя.\n","*   **PostgreSQL:** Полное содержимое эталонного XML-файла, который связан с найденными документами через `parent_doc_id`.\n","\n","#### 2. Как он задаётся в коде?\n","Посмотрите на логику внутри функции `rag()` в файле `rag.py`:\n","\n","```python\n","# Шаг A: Ищем чанки в векторной базе\n","docs = await chroma.asimilarity_search(search_query.content, k=3)\n","context_text = \"\\n\\n\".join([d.page_content for d in docs])\n","\n","# Шаг B: Ищем связанный XML в PostgreSQL по ID документа\n","query = xml_documents_table.select().where(xml_documents_table.c.parent_doc_id == parent_id)\n","db_xml = await database.fetch_one(query)\n","\n","if db_xml:\n","    # Добавляем XML к тексту для полноты картины\n","    context_text += f\"\\n\\nСвязанный XML контент:\\n{db_xml['xml_content']}\"\n","\n","# Шаг C: Передаем итоговую строку в промпт\n","response = await chain.ainvoke({\"context\": context_text, \"input\": search_query.content})\n","```\n","\n","#### 3. Зачем это нужно?\n","*   **Текст из Chroma** дает модели понимание логики процесса.\n","*   **XML из Postgres** дает модели пример структуры, чтобы она могла сгенерировать новый XML по аналогии или извлечь данные точно по схеме.\n","\n","В итоге в промпт вместо `{context}` подставляется огромный блок текста со всеми найденными инструкциями и примерами кода."]},{"cell_type":"markdown","source":["### извлечения сущностей"],"metadata":{"id":"NFJ-6yYd1iAM"}},{"cell_type":"markdown","metadata":{"id":"b23549cf"},"source":["#### Инструкция по составлению промпта для извлечения сущностей (Table Mode)\n","\n","Цель этого режима — превратить неструктурированный текст в четкий JSON-массив или таблицу. Чтобы это работало стабильно, промпт должен содержать:\n","\n","1.  **Спецификация JSON:** Укажите конкретные ключи, которые вы хотите видеть (например, `Тип сущности`, `Событие`, `Связи`).\n","2.  **Запрет на лишнее:** Требуйте возвращать **только** массив JSON без вступительных слов.\n","3.  **Обработка условий:** Инструктируйте модель, как помечать развилки (Gateways) или условия перехода.\n","4.  **Язык:** Укажите, что значения должны оставаться на русском языке.\n","\n","#### Пример структуры:\n","*   *\"Проанализируй текст процесса и представь его в виде списка объектов. Каждый объект должен содержать порядковый номер, название действия и исполнителя. Выдай ответ строго в формате JSON.\"*"]},{"cell_type":"code","metadata":{"id":"927198d7","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839466812,"user_tz":-420,"elapsed":46,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"108b77a0-b88d-48c8-8088-2f971dbdb79f"},"source":["%%writefile bpmn_table_rules.py\n","\n","template = \"\"\"Ты — аналитик бизнес-процессов. Твоя задача — извлечь структурированную информацию из текста и представить её в формате JSON.\n","### ПРАВИЛА:\n","1. Используй контекст для понимания терминологии: {{context}}\n","2. Вывод должен быть СТРОГО в формате JSON-массива объектов.\n","3. Пример JSON-массива (в одну строку):\n","[{\"Тип сущности\": \"Событие\", \"Название\": \"Начало процесса\", \"Описание\": \"Инициирует выполнение бизнес‑процесса\", \"Связи\": \"→ Задача 1\"}, {\"Тип сущности\": \"Задача\", \"Название\": \"Проанализировать документ\", \"Описание\": \"Изучение содержания загруженного документа\", \"Связи\": \"← Событие 1, → Шлюз 1\", \"Исполнитель\": \"Эсперт отдела цифровой трансформации\"}, {\"Тип сущности\": \"Шлюз\", \"Название\": \"Проверка условий\", \"Описание\": \"Определяет дальнейший путь выполнения процесса\", \"Связи\": \"← Задача 1, → Задача 2 или Задача 3\"}]\n","4. Не добавляй никаких пояснений, только JSON-массив.\n","5. Все названия элементов должны быть на русском языке.\n","\n","### ПРАВИЛА BPMN:\n","1. Используйте символы и надписи, чтобы процессную логику можно было понять из напечатанной диаграммы.\n","2. Сделайте модель иерархической, поместив каждый уровень процесса на отдельную страницу.\n","3. Используйте пул «черный ящик» для изображения клиента, другого внешнего потребителя или поставщика.\n","4. Начинайте процесс, взаимодействующий с внешним потребителем, начальным событием-сообщением, получающим поток сообщений из пула «черный ящик».\n","5. Моделируйте внутренние подразделения организации дорожками в рамках одного процессного пула, а не отдельными пулами. Отдельные пулы изображают независимые процессы.\n","6. Подписывайте процессный пул названием процесса, а пул «черный ящик» — названием внешней сущности.\n","7. Обозначьте успешные конечные состояния процесса (подпроцесса) и отклонения отдельными конечными событиями и маркируйте их названиями конечных состояний.\n","8. Называйте действия по шаблону «глагол — существительное».\n","9. В процессе верхнего уровня задайте тип начального события, чтобы показать, как он запускается.\n","Если процесс запускается внешним запросом, используйте начальное событие-сообщение. Событие должно называться Получить [название потока сообщений].\n","Если процесс запускается по расписанию, используйте начальное событие-таймер. Надпись на событии должна конкретизировать расписание, например, ежемесячно или по понедельникам в 8:00.\n","Если процесс запускается исполнителем вручную, используйте простое начальное событие. Надписывать его не обязательно.\n","10. Если за подпроцессом следует развилка, надписанная с вопросительным знаком, то у подпроцесса должно быть несколько конечных событий\n","и название одного из них должно совпадать с названием развилки.\n","11. Для каждого события-сообщения покажите поток сообщений.\n","12. Поддерживайте соответствие потоков сообщений на родительской и дочерних диаграммах.\n","13. Надписывайте поток сообщений названием сообщения.\n","14. Два конечных события на одной диаграмме не должны называться одинаково.\n","15. Два действия в одной модели не должны называться одинаково.\n","16. У подпроцесса должно быть одно простое начальное событие.\n","17. Процессный пул на дочерней диаграмме (если он изображен) должен быть подписан названием процесса верхнего уровня, а не названием подпроцесса.\n","18. В иерархической модели дочерняя диаграмма не должна содержать процессы верхнего уровня.\n","19. Не используйте для слияния альтернативных маршрутов развилку «или/или», если следующий по потоку элемент не есть развилка. Просто соедините потоки управления со следующим элементом.\n","20. Не используйте развилку «и» для слияния параллельных маршрутов перед простым конечным событием. Простое конечное событие подразумевает слияние. (если схема НЕ исполняема)\n","21. Поток управления не может пересекать границы пула (процесса).\n","22. Поток управления не может пересекать границы подпроцесса.\n","23. Поток сообщений не может соединять элементы внутри одного пула.\n","24. Поток управления может соединять только действия, развилки и события, причем оба конца потока управления должны быть соединены с каким-то из этих элементов.\n","25. Поток сообщений может соединяться только с действием, событием-сообщением (или множественным событием) или границей пула «черный ящик»,\n","причем оба конца потока сообщений должны быть соединены с каким-то из этих элементов.\n","\n","### ТЕКСТ ДЛЯ АНАЛИЗА:\n","{{input}}\"\"\"\n"],"execution_count":35,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing bpmn_table_rules.py\n"]}]},{"cell_type":"code","source":["# Переходим в папку Проекта\n","%cd {app_path}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839480121,"user_tz":-420,"elapsed":48,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"011776e5-49de-480b-e22b-29093421877d","id":"I15BRtlemVzp"},"execution_count":36,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app\n"]}]},{"cell_type":"markdown","source":["## Создаём API\n","в директории `routers` создать файл `rag.py`, в котором пропишем сам API."],"metadata":{"id":"WuOE-SBCsCfK"}},{"cell_type":"code","source":["# Переходим в папку routers внутри app\n","%cd {app_path}/routers"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839484017,"user_tz":-420,"elapsed":33,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"c46478b2-16bf-4175-fc6f-e6d1ddc0b25b","id":"UD36rL5wsCfL"},"execution_count":37,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app/routers\n"]}]},{"cell_type":"code","source":["%%writefile rag.py\n","\n","import uuid\n","import os\n","from dependencies import chroma, llm, database, xml_documents_table, generated_results_table\n","from prompts.bpmn_xml_rules import template as xml_template\n","from prompts.bpmn_table_rules import template as table_template\n","from schemas.search_query import SearchQuery\n","from schemas.db_models import GeneratedResult\n","from fastapi import APIRouter, Body, HTTPException, Query\n","from langchain_core.prompts import ChatPromptTemplate\n","import datetime\n","\n","# Импортируем загрузчик для чтения файлов с диска\n","from routers.document_loader import _read_document_content\n","from fastapi import UploadFile\n","import io\n","\n","router = APIRouter()\n","\n","@router.post(\"/search/rag\")\n","async def rag(search_query: SearchQuery = Body(), document_path: str = Query(None)):\n","    if not search_query.content:\n","        raise HTTPException(status_code=400, detail=\"Запрос пуст\")\n","\n","    # 1. Загрузка внешнего документа, если указан путь\n","    extra_doc_content = \"\"\n","    if document_path:\n","        if not os.path.exists(document_path):\n","            raise HTTPException(status_code=404, detail=\"Файл по указанному пути не найден\")\n","\n","        # Создаем временный объект UploadFile для использования существующей функции\n","        with open(document_path, \"rb\") as f:\n","            file_content = f.read()\n","            fake_file = UploadFile(filename=os.path.basename(document_path), file=io.BytesIO(file_content))\n","            extra_doc_content = await _read_document_content(fake_file)\n","\n","    # 2. Поиск в Chroma\n","    docs = await chroma.asimilarity_search(search_query.content, k=3)\n","    context_text = \"\\n\\n\".join([d.page_content for d in docs])\n","    parent_id = docs[0].metadata.get(\"parent_doc_id\") if docs else \"unknown\"\n","\n","    # 3. Поиск XML в Postgres\n","    query = xml_documents_table.select().where(xml_documents_table.c.parent_doc_id == parent_id)\n","    db_xml = await database.fetch_one(query)\n","    if db_xml:\n","        context_text += f\"\\n\\nПример эталонного XML:\\n{db_xml['xml_content']}\"\n","\n","    # 4. Формируем комбинированный ввод\n","    # В input попадает и инструкция пользователя, и текст целевого документа\n","    full_input = search_query.content\n","    if extra_doc_content:\n","        full_input = f\"ИНСТРУКЦИЯ: {search_query.content}\\n\\nТЕКСТ ДОКУМЕНТА ДЛЯ ОБРАБОТКИ:\\n{extra_doc_content}\"\n","\n","    # 5. Выбор шаблона\n","    user_request = search_query.content.lower()\n","    is_xml_workflow = \"xml\" in user_request\n","    selected_template = xml_template if is_xml_workflow else table_template\n","    result_type = \"xml\" if is_xml_workflow else \"json\"\n","\n","    chat_prompt = ChatPromptTemplate.from_messages([\n","        (\"system\", selected_template),\n","        (\"human\", \"{input}\"),\n","    ])\n","\n","    chain = chat_prompt | llm\n","    response = await chain.ainvoke({\"context\": context_text, \"input\": full_input})\n","\n","    # 6. Сохранение и ответ\n","    new_id = uuid.uuid4()\n","    insert_query = generated_results_table.insert().values(\n","        id=new_id,\n","        parent_doc_id=parent_id,\n","        result_type=result_type,\n","        content=response.content,\n","        created_at=datetime.datetime.utcnow()\n","    )\n","    await database.execute(insert_query)\n","\n","    return {\n","        \"result_link\": f\"/get/result/{new_id}\",\n","        \"type\": result_type,\n","        \"parent_doc_id\": parent_id\n","    }\n","\n","@router.get(\"/get/result/{result_id}\")\n","async def get_result(result_id: uuid.UUID):\n","    query = generated_results_table.select().where(generated_results_table.c.id == result_id)\n","    result = await database.fetch_one(query)\n","    if not result:\n","        raise HTTPException(status_code=404, detail=\"Результат не найден\")\n","    return {\"content\": result[\"content\"], \"type\": result[\"result_type\"]}\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839489105,"user_tz":-420,"elapsed":28,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"379ffd3f-f797-4547-e9a6-5c2a60fdd34f","id":"DF42mY4ysCfM"},"execution_count":38,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing rag.py\n"]}]},{"cell_type":"code","source":["# Переходим в папку Проекта\n","%cd {app_path}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839501164,"user_tz":-420,"elapsed":10,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"bd6c9e6b-362b-4b15-daf6-147484f46db3","id":"5ovyndtksCfN"},"execution_count":39,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Проект/TUSUR_Project/app\n"]}]},{"cell_type":"markdown","source":["## Тест API"],"metadata":{"id":"stp3FUf6sCfO"}},{"cell_type":"code","source":["%%writefile test_api_rag.py\n","\n","from fastapi import FastAPI\n","from routers.rag import router as rag_router\n","from dependencies import database, connect_and_create_db, disconnect_db\n","from contextlib import asynccontextmanager\n","\n","@asynccontextmanager\n","async def lifespan(app: FastAPI):\n","    # Выполняется при запуске: подключаемся к БД и создаем таблицы\n","    await connect_and_create_db()\n","    yield\n","    # Выполняется при остановке: закрываем соединение\n","    await disconnect_db()\n","\n","# Создаем приложение с жизненным циклом (lifespan)\n","app = FastAPI(\n","    title=\"TUSUR RAG Service Test\",\n","    description=\"Тестирование RAG с поддержкой генерации BPMN XML и извлечения сущностей\",\n","    lifespan=lifespan\n",")\n","\n","# Подключаем роутер с нашей бизнес-логикой\n","app.include_router(rag_router, tags=[\"RAG\"])\n","\n","# Заметка для пользователя:\n","# Чтобы запустить этот тест в Colab, используйте uvicorn в отдельной ячейке:\n","# !uvicorn test_api_rag:app --host 0.0.0.0 --port 8000"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778839504410,"user_tz":-420,"elapsed":39,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"0839a6c3-e0d7-4509-eb7a-fbc467e8521e","id":"NhteenM4sCfO"},"execution_count":40,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing test_api_rag.py\n"]}]},{"cell_type":"markdown","metadata":{"id":"159be263"},"source":["### 🛠 Инструкция по проверке работоспособности RAG (rag.py)\n","\n","Этот роутер отвечает за самую сложную часть: поиск в базе и генерацию ответа от LLM. Вот как его проверить:\n","\n","#### 1. Подготовка базы данных\n","Запустите ячейку ниже, чтобы убедиться, что в PostgreSQL создана таблица `generated_results`. Без неё эндпоинт выдаст ошибку при попытке сохранить результат.\n","\n","#### 2. Запуск сервера\n","Выполните команду в ячейке:\n","```bash\n","!uvicorn test_api_rag:app --host 0.0.0.0 --port 8000\n","```\n","\n","#### 3. Тестирование через Swagger UI\n","Откройте `http://localhost:8000/docs` и найдите `POST /search/rag`.\n","\n","**Сценарий А: Генерация BPMN XML**\n","*   В поле `content` введите: *\"Создай BPMN XML для процесса закупки на основе найденных документов\"* (ключевое слово **xml** активирует нужный шаблон).\n","*   В ответе вы получите `result_link` (например, `/get/result/uuid...`).\n","\n","**Сценарий Б: Извлечение сущностей (JSON)**\n","*   В поле `content` введите: *\"Составь таблицу сущностей для процесса закупки\"*.\n","*   Система переключится на JSON-шаблон.\n","\n","**Сценарий В: Обработка локального файла**\n","*   Загрузите файл (например, `test.docx`) в папку проекта.\n","*   В Swagger в параметре `document_path` укажите полный путь: `/content/drive/.../test.docx`.\n","*   Модель проанализирует именно этот файл, используя базу знаний как справочник.\n","\n","#### 4. Получение результата\n","Используйте `GET /get/result/{result_id}` с полученным ID, чтобы увидеть сгенерированный код или JSON."]},{"cell_type":"code","metadata":{"id":"e6dedf88"},"source":["import asyncio\n","from dependencies import connect_and_create_db\n","\n","# Здесь нам не нужен engine или metadata напрямую, так как connect_and_create_db\n","# уже вызывает metadata.create_all(engine) и создаёт все таблицы.\n","# Этот вызов теперь просто обеспечивает, что таблицы будут созданы.\n","\n","# Асинхронная функция-обертка для вызова connect_and_create_db\n","async def ensure_db_tables():\n","    print(\"Проверка и создание таблиц PostgreSQL...\")\n","    await connect_and_create_db()\n","\n","# Запуск асинхронной функции\n","asyncio.run(ensure_db_tables())\n"],"execution_count":null,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"704cd38f"},"source":["# Шаг 3: мониторинг и проверка состояния системы\n","\n","Создадим API для проверки состояния всех ключевых компонентов: ChromaDB, PostgreSQL, SQLite Record Manager и моделей Ollama."]},{"cell_type":"markdown","metadata":{"id":"56374965"},"source":["## Файл `monitor_router.py`\n","\n","Этот файл будет содержать эндпоинты для проверки статуса различных компонентов приложения."]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"c800d675","executionInfo":{"status":"ok","timestamp":1778839520826,"user_tz":-420,"elapsed":43,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"8cc6bc78-cced-496a-ee9f-d4be10b7a646"},"source":["%%writefile routers/monitor_router.py\n","\n","from fastapi import APIRouter, HTTPException\n","from dependencies import chroma, database, record_manager, llm, embedding_model, xml_documents_table, generated_results_table\n","\n","router = APIRouter()\n","\n","@router.get(\"/monitor/chroma\")\n","async def check_chroma_status():\n","    \"\"\"Проверяет статус ChromaDB.\"\"\"\n","    try:\n","        # Попытка получить информацию о коллекции для проверки доступности\n","        collection_info = await chroma.aget()\n","        count = len(collection_info['ids']) # Считаем количество элементов в коллекции\n","        return {\"status\": \"ok\", \"message\": \"ChromaDB доступна\", \"collection_count\": count}\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=f\"ChromaDB недоступна: {str(e)}\")\n","\n","@router.get(\"/monitor/postgresql\")\n","async def check_postgresql_status():\n","    \"\"\"Проверяет статус PostgreSQL и наличие таблиц.\"\"\"\n","    try:\n","        await database.connect()\n","        await database.fetch_one(\"SELECT 1\") # Простая проверка соединения\n","\n","        # Проверка наличия и количества записей в xml_documents_table\n","        xml_count_query = xml_documents_table.count()\n","        xml_count = await database.fetch_val(xml_count_query)\n","\n","        # Проверка наличия и количества записей в generated_results_table\n","        generated_count_query = generated_results_table.count()\n","        generated_count = await database.fetch_val(generated_count_query)\n","\n","        await database.disconnect()\n","        return {\n","            \"status\": \"ok\",\n","            \"message\": \"PostgreSQL доступна\",\n","            \"xml_documents_count\": xml_count,\n","            \"generated_results_count\": generated_count\n","        }\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=f\"PostgreSQL недоступна: {str(e)}\")\n","\n","@router.get(\"/monitor/sqlite_record_manager\")\n","async def check_sqlite_record_manager_status():\n","    \"\"\"Проверяет статус SQLite Record Manager.\"\"\"\n","    try:\n","        # Проверяем, что схема существует и можем выполнить простой запрос\n","        # aget_keys вернет пустой список, если таблица пуста, но не вызовет ошибку\n","        keys = await record_manager.aget_keys(list_keys=[\"non_existent_key\"], namespace=\"Stardew\")\n","\n","        # Можно также попытаться получить общее количество записей\n","        # Для этого нужно напрямую обратиться к базе данных SQLite\n","        import sqlite3\n","        from constants import RECORD_MANAGER\n","        db_path = RECORD_MANAGER.replace(\"sqlite+aiosqlite:///\", \"\")\n","        conn = sqlite3.connect(db_path)\n","        cursor = conn.cursor()\n","        cursor.execute(\"SELECT COUNT(*) FROM upsertion_record WHERE namespace = 'Stardew'\")\n","        record_count = cursor.fetchone()[0]\n","        conn.close()\n","\n","        return {\"status\": \"ok\", \"message\": \"SQLite Record Manager доступен\", \"record_count\": record_count}\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=f\"SQLite Record Manager недоступен: {str(e)}\")\n","\n","@router.get(\"/monitor/ollama_llm\")\n","async def check_ollama_llm_status():\n","    \"\"\"Проверяет доступность Ollama LLM (gemma3:4b) .\"\"\"\n","    try:\n","        response = await llm.ainvoke(\"Привет, как дела?\")\n","        if response.content: # Проверяем, что ответ не пустой\n","            return {\"status\": \"ok\", \"message\": \"Ollama LLM (gemma3:4b) доступна\", \"test_response\": response.content[:50] + \"...\"}\n","        else:\n","            raise HTTPException(status_code=500, detail=\"Ollama LLM вернула пустой ответ.\")\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=f\"Ollama LLM (gemma3:4b) недоступна: {str(e)}\")\n","\n","@router.get(\"/monitor/ollama_embeddings\")\n","async def check_ollama_embeddings_status():\n","    \"\"\"Проверяет доступность Ollama Embeddings (snowflake-arctic-embed2:latest).\"\"\"\n","    try:\n","        # Попытка сгенерировать эмбеддинг для тестовой строки\n","        embedding = await embedding_model.aembed_query(\"это тестовая строка\")\n","        if isinstance(embedding, list) and len(embedding) > 0: # Проверяем, что получен список чисел\n","            return {\"status\": \"ok\", \"message\": \"Ollama Embeddings (snowflake-arctic-embed2:latest) доступна\", \"embedding_length\": len(embedding)}\n","        else:\n","            raise HTTPException(status_code=500, detail=\"Ollama Embeddings вернула некорректный результат.\")\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=f\"Ollama Embeddings (snowflake-arctic-embed2:latest) недоступна: {str(e)}\")\n"],"execution_count":41,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing routers/monitor_router.py\n"]}]},{"cell_type":"markdown","metadata":{"id":"563a4ad7"},"source":["## Тест API для `monitor_router.py`\n","\n","Создадим временное FastAPI приложение для тестирования эндпоинтов мониторинга."]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"c134621c","executionInfo":{"status":"ok","timestamp":1778839545842,"user_tz":-420,"elapsed":50,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"06893c3e-e93b-4d44-cb5b-d473b7e4b5a5"},"source":["%%writefile test_api_monitor.py\n","\n","from fastapi import FastAPI\n","from routers.monitor_router import router as monitor_router\n","from dependencies import connect_and_create_db, disconnect_db\n","from contextlib import asynccontextmanager\n","\n","@asynccontextmanager\n","async def lifespan(app: FastAPI):\n","    # Выполняется при запуске: подключаемся к БД и создаем таблицы\n","    await connect_and_create_db()\n","    yield\n","    # Выполняется при остановке: закрываем соединение\n","    await disconnect_db()\n","\n","app = FastAPI(\n","    title=\"Тестирование сервиса мониторинга проекта\",\n","    description=\"Тестирование эндпоинтов мониторинга для TUSUR RAG BPMN Generator\",\n","    lifespan=lifespan\n",")\n","\n","app.include_router(monitor_router, tags=[\"Monitoring\"])\n","\n","# Заметка для пользователя:\n","# Чтобы запустить этот тест в Colab, используйте uvicorn в отдельной ячейке:\n","# !uvicorn test_api_monitor:app --host 0.0.0.0 --port 8000 --reload\n"],"execution_count":42,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing test_api_monitor.py\n"]}]},{"cell_type":"markdown","metadata":{"id":"a887d9c4"},"source":["### 🛠 Инструкция по проверке `monitor_router.py`\n","\n","1.  **Запустите сервер:**\n","    В новой ячейке выполните команду:\n","    ```bash\n","    !uvicorn test_api_monitor:app --host 0.0.0.0 --port 8000 --reload\n","    ```\n","\n","2.  **Откройте Swagger UI:**\n","    Перейдите по адресу `http://localhost:8000/docs` в вашем браузере.\n","\n","3.  **Проверьте эндпоинты мониторинга:**\n","    *   `GET /monitor/chroma`: Проверит доступность ChromaDB и количество документов в коллекции.\n","    *   `GET /monitor/postgresql`: Проверит соединение с PostgreSQL и количество записей в таблицах `xml_documents` и `generated_results`.\n","    *   `GET /monitor/sqlite_record_manager`: Проверит доступность SQLite Record Manager и количество записей в `upsertion_record`.\n","    *   `GET /monitor/ollama_llm`: Проверит доступность и базовую функциональность LLM (gemma3:4b).\n","    *   `GET /monitor/ollama_embeddings`: Проверит доступность и функциональность модели эмбеддингов (snowflake-arctic-embed2:latest).\n","\n","    Для каждого эндпоинта нажмите \"Try it out\" и затем \"Execute\". В ответе вы должны увидеть `status: \"ok\"` и соответствующую информацию, если все работает корректно.\n","\n","Эти проверки помогут убедиться, что все компоненты системы RAG работают до того, как вы начнете загружать документы или генерировать ответы."]},{"cell_type":"markdown","metadata":{"id":"8e94b4c1"},"source":["# Шаг 4: Основное приложение `main.py`\n","\n","Теперь, когда все компоненты (загрузчик документов, логика RAG и мониторинг) готовы, мы объединим их в одном FastAPI приложении `main.py`. Этот файл будет точкой входа для всего сервиса."]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0d46a54b","executionInfo":{"status":"ok","timestamp":1778839555076,"user_tz":-420,"elapsed":29,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"6f4b4593-5fad-4378-ab3a-7a450604c2fd"},"source":["%%writefile main.py\n","\n","from fastapi import FastAPI\n","from routers import document_loader, rag, monitor_router\n","from dependencies import connect_and_create_db, disconnect_db\n","from contextlib import asynccontextmanager\n","\n","@asynccontextmanager\n","async def lifespan(app: FastAPI):\n","    # Выполняется при запуске приложения: подключаемся к БД и создаем таблицы\n","    print(\"Запуск приложения: Подключение к БД и проверка таблиц...\")\n","    await connect_and_create_db()\n","    print(\"Приложение запущено.\")\n","    yield\n","    # Выполняется при остановке приложения: закрываем соединение с БД\n","    print(\"Остановка приложения: Отключение от БД...\")\n","    await disconnect_db()\n","    print(\"Приложение остановлено.\")\n","\n","app = FastAPI(\n","    title=\"TUSUR RAG BPMN Generator Service\",\n","    description=\"API для генерации BPMN XML и извлечения сущностей с использованием RAG на основе документов и Ollama\",\n","    version=\"1.0.0\",\n","    lifespan=lifespan\n",")\n","\n","# Включаем роутеры\n","app.include_router(document_loader.router, prefix=\"/document\", tags=[\"Document Loading\"])\n","app.include_router(rag.router, prefix=\"/rag\", tags=[\"RAG Logic\"])\n","app.include_router(monitor_router.router, prefix=\"/system\", tags=[\"System Monitoring\"])\n","\n","@app.get(\"/\", tags=[\"Root\"])\n","async def read_root():\n","    return {\"message\": \"Запущен сервис генератора BPMN RAG! Документацию по API можно найти по адресу: http://localhost:8000/docs.\"}\n"],"execution_count":43,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing main.py\n"]}]},{"cell_type":"markdown","metadata":{"id":"f9aed741"},"source":["## 🛠 Инструкция по запуску и эксплуатации `main.py`\n","\n","Файл `main.py` теперь содержит все эндпоинты, и он является центральной точкой для вашего сервиса. Вот как его запустить и проверить:\n","\n","#### 1. Убедитесь, что Ollama запущен\n","Перед запуском FastAPI убедитесь, что Ollama сервер работает и модели `gemma3:4b` и `snowflake-arctic-embed2:latest` загружены и доступны. Если Ollama не запущена, сервис не сможет использовать LLM и модели эмбеддингов.\n","\n","#### 2. Запустите Uvicorn\n","В новой ячейке Colab (или в вашем терминале, если вы работаете локально) выполните следующую команду:\n","\n","```bash\n","!uvicorn main:app --host 0.0.0.0 --port 8000 --reload\n","```\n","\n","*   `main:app`: Указывает Uvicorn запустить объект `app` из файла `main.py`.\n","*   `--host 0.0.0.0`: Позволяет приложению быть доступным извне (важно для Colab).\n","*   `--port 8000`: Указывает порт, на котором будет работать сервис.\n","*   `--reload`: (Опционально, для разработки) Перезапускает сервер при изменениях в коде.\n","\n","#### 3. Доступ к Swagger UI\n","После запуска сервера откройте ваш браузер и перейдите по адресу: `http://localhost:8000/docs`.\n","\n","Там вы найдете полную интерактивную документацию по всем доступным эндпоинтам:\n","\n","*   **`Document Loading` (`/document/...`)**:\n","    *   `POST /document/load/doc_as_json`: Загрузка документа в виде JSON для индексации.\n","    *   `POST /document/load/doc_as_file_and_xml`: Загрузка основного документа и связанного с ним XML-файла.\n","    *   `GET /document/get/documents`: Получение проиндексированных чанков из ChromaDB.\n","\n","*   **`RAG Logic` (`/rag/...`)**:\n","    *   `POST /rag/search/rag`: Основной эндпоинт для запросов RAG (генерация XML или извлечение сущностей).\n","    *   `GET /rag/get/result/{result_id}`: Получение сгенерированного результата по ID.\n","\n","*   **`System Monitoring` (`/system/...`)**:\n","    *   `GET /system/monitor/chroma`: Проверка статуса ChromaDB.\n","    *   `GET /system/monitor/postgresql`: Проверка статуса PostgreSQL.\n","    *   `GET /system/monitor/sqlite_record_manager`: Проверка статуса SQLite Record Manager.\n","    *   `GET /system/monitor/ollama_llm`: Проверка доступности LLM Ollama.\n","    *   `GET /system/monitor/ollama_embeddings`: Проверка доступности Ollama Embeddings.\n","\n","#### 4. Проверка работы\n","1.  **Проверьте `GET /`**: Убедитесь, что вы видите сообщение `{\"message\": \"Запущен сервис генератора BPMN RAG! Документацию по API можно найти по адресу: `http://localhost:8000/docs`.\"}`.\n","2.  **Загрузите документ**: Используйте `POST /document/load/doc_as_file_and_xml` для загрузки тестового документа (например, TXT и XML).\n","3.  **Выполните RAG запрос**: Используйте `POST /rag/search/rag` для получения BPMN XML или извлечения сущностей.\n","4.  **Мониторинг**: Регулярно проверяйте эндпоинты `GET /system/monitor/...` для отслеживания работоспособности компонентов.\n","\n","Это завершает этап разработки API. Теперь у вас есть полностью функционирующий RAG-сервис, готовый к использованию!"]},{"cell_type":"markdown","metadata":{"id":"18a0e338"},"source