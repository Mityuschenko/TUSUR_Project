-41e9-fb4e-4126756937e7"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Модуль 12/TUSUR/app\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"601192e3","executionInfo":{"status":"ok","timestamp":1778298822570,"user_tz":-420,"elapsed":5,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"4a34331f-ee87-460f-aadc-5b76ec85e7c5"},"source":["%%writefile constants.py\n","\n","CHROMA_PATH = \"./store\"\n","\n","CHROMA_COLLECTION = \"embeddings\"\n","\n","EMBEDDINGS_MODEL = \"snowflake-arctic-embed2:latest\"\n","\n","RECORD_MANAGER = \"sqlite+aiosqlite:///record_manager_cache.sql\"\n","\n","LLM_MODEL = \"gemma3:4b\""],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Overwriting constants.py\n"]}]},{"cell_type":"markdown","source":["## Создание класса Chroma\n","\n","Чтобы работа с Chroma была корректной, наследуемся от базового класса Chroma с добавлением поддержки асинхронного удаления"],"metadata":{"id":"S7fQCMndoZAZ"}},{"cell_type":"code","source":["%%writefile chroma_async.py\n","\n","# Чтобы работа с Chroma была корректной, наследуемся от базового класса Chroma с добавлением поддержки асинхронного удаления\n","\n","from typing import Any\n","\n","from langchain_chroma import Chroma\n","\n","\n","class AsyncChroma(Chroma):\n","    \"\"\"Async Chroma.\"\"\"\n","\n","    async def adelete(self, *args: Any, **kwargs: Any) -> bool | None:\n","        \"\"\"Async delete by vector ID or other criteria.\"\"\"\n","        return await super().adelete(*args, **kwargs)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"AjtQqwb3PDWW","executionInfo":{"status":"ok","timestamp":1778298825439,"user_tz":-420,"elapsed":10,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"43193ce5-0e4e-4f7f-e8b1-94827360b2cd"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Overwriting chroma_async.py\n"]}]},{"cell_type":"markdown","source":["## Основные классы для работы с Chroma и LLM"],"metadata":{"id":"JX5fFtMro3aq"}},{"cell_type":"code","source":["\n","print(\"Текущая директория:\", os.getcwd())\n","print(\"Файлы в директории:\", os.listdir('.'))\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ItfKNPFhv0Tr","executionInfo":{"status":"ok","timestamp":1778403598237,"user_tz":-420,"elapsed":13,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"c81f6989-63e5-48df-a8cd-d16b13494f12"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Текущая директория: /content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Модуль 12/TUSUR/app\n","Файлы в директории: ['__pycache__', '.ipynb_checkpoints', 'prompts', 'routers', 'schemas', 'store', 'constants.py', 'chroma_async.py', 'dependencies.py', 'record_manager_cache.sql', 'test_api_document_loader.py']\n"]}]},{"cell_type":"code","source":["# @title Добавление пути к файлам *.py\n","sys.path.append('/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Модуль 12/TUSUR/app')"],"metadata":{"id":"YKlbV6fKwV3o"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["%%writefile dependencies.py\n","\n","from chroma_async import AsyncChroma\n","from constants import (\n","    CHROMA_COLLECTION,\n","    CHROMA_PATH,\n","    EMBEDDINGS_MODEL,\n","    LLM_MODEL,\n","    RECORD_MANAGER,\n",")\n","from langchain_classic.indexes import SQLRecordManager\n","from langchain_ollama import ChatOllama, OllamaEmbeddings\n","\n","# Инициализация эмбеддингов\n","embedding_model = OllamaEmbeddings(model=EMBEDDINGS_MODEL)\n","\n","# Подключение к Chroma\n","chroma = AsyncChroma(\n","    collection_name=CHROMA_COLLECTION,\n","    persist_directory=CHROMA_PATH,\n","    embedding_function=embedding_model,\n",")\n","\n","# Инициализация менеджера записей для отслеживания состояния документов\n","record_manager = SQLRecordManager(\n","    namespace=\"Stardew\", db_url=RECORD_MANAGER, async_mode=True\n",")\n","\n","# Инициализация LLM\n","llm = ChatOllama(model=LLM_MODEL)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jJIhl067pMd5","executionInfo":{"status":"ok","timestamp":1778298840460,"user_tz":-420,"elapsed":7,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"13f7eaae-7a04-476e-b80e-f0c5b7d6fe41"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Overwriting dependencies.py\n"]}]},{"cell_type":"markdown","source":["# Шаг 1: загрузка документов в базу данных\n","\n","без пользовательского интерфейса"],"metadata":{"id":"pnoPBNsdp_Q5"}},{"cell_type":"code","source":["# @title Запуск ячейки ТОЛЬКО если нужно создать файл базы данных\n","\n","# в данном случае имя файла базы данных record_manager_cache.sql\n","\n","# Импортируем модуль asyncio для работы с асинхронным кодом и управления циклом событий\n","import asyncio\n","\n","# Импортируем путь к базе данных SQLite из модуля с константами нашего приложения\n","from constants import RECORD_MANAGER\n","\n","# Импортируем класс SQLRecordManager из LangChain для управления индексами документов\n","from langchain_classic.indexes import SQLRecordManager\n","\n","# Инициализируем менеджер записей, настраивая его параметры для работы с базой данных\n","record_manager = SQLRecordManager(\n","    # Указываем уникальный префикс (пространство имен) для изоляции записей этого проекта\n","    namespace=\"Stardew\",\n","    # Передаем строку подключения к нашей локальной базе данных SQLite из константы\n","    db_url=RECORD_MANAGER,\n","    # Включаем асинхронный режим работы для бесконфликтного выполнения внутри асинхронного API\n","    async_mode=True\n",")\n","\n","# Объявляем главную асинхронную функцию, которая будет выполнять инициализацию базы\n","async def main():\n","    # Асинхронно создаем таблицы и схему данных в SQLite, если они еще не созданы\n","    await record_manager.acreate_schema()\n","\n","# Проверяем, что скрипт запущен напрямую пользователем, а не импортирован как модуль\n","#if __name__ == \"__main__\":\n","    # Получаем текущий или создаем новый цикл событий (event loop) для асинхронных задач\n","  #  loop = asyncio.get_event_loop()\n","    # Запускаем цикл событий и блокируем выполнение, пока функция main() не завершится\n"," #   loop.run_until_complete(main())\n","\n","# Замените весь блок if __name__ == \"__main__\": на одну строку:\n","await main()\n","\n"],"metadata":{"id":"UfeOUeX721ml"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# @title Посмотреть структуру таблиц\n","\n","# Путь к созданному файлу базы данных на вашем Google Диске\n","db_path = '/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Модуль 12/TUSUR/app/record_manager_cache.sql'\n","\n","# Подключаемся к базе данных\n","conn = sqlite3.connect(db_path)\n","cursor = conn.cursor()\n","\n","# Получаем список всех таблиц и их SQL-структуру (схему)\n","cursor.execute(\"SELECT name, sql FROM sqlite_master WHERE type='table';\")\n","tables = cursor.fetchall()\n","\n","# Выводим результат на экран\n","for name, sql in tables:\n","    print(f\"Таблица: {name}\")\n","    print(f\"Схема создания:\\n{sql}\\n\" + \"-\"*50)\n","\n","# Закрываем соединение\n","conn.close()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"dxuAOJvq5cT7","executionInfo":{"status":"ok","timestamp":1778403658642,"user_tz":-420,"elapsed":407,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"c9d99b41-5092-4ea3-fd76-287f7a92d230"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Таблица: upsertion_record\n","Схема создания:\n","CREATE TABLE upsertion_record (\n","\tuuid VARCHAR NOT NULL, \n","\t\"key\" VARCHAR, \n","\tnamespace VARCHAR NOT NULL, \n","\tgroup_id VARCHAR, \n","\tupdated_at FLOAT, \n","\tPRIMARY KEY (uuid), \n","\tCONSTRAINT uix_key_namespace UNIQUE (\"key\", namespace)\n",")\n","--------------------------------------------------\n"]}]},{"cell_type":"markdown","source":["## Создадим схему\n","для единого формата сохранения документов с указанием содержимого (content) и метаданных документа.\n","\n","Метаданные являются необязательными."],"metadata":{"id":"O0xgrZJU-A7S"}},{"cell_type":"code","source":["# Переходим в папку schemas внутри app\n","%cd {app_path}/schemas"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"nE0Hen2QCMsc","executionInfo":{"status":"ok","timestamp":1778301818664,"user_tz":-420,"elapsed":23,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"9308d8fa-fc08-4480-9387-1b13e627ed26"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Модуль 12/TUSUR/app/schemas\n"]}]},{"cell_type":"code","source":["%%writefile __init__.py"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XfkM3S9FDJym","executionInfo":{"status":"ok","timestamp":1778301991109,"user_tz":-420,"elapsed":18,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"964ce0eb-51ec-4634-8343-e05f53c6e24e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing __init__.py\n"]}]},{"cell_type":"code","source":["%%writefile document_upload.py\n","\n","from pydantic import BaseModel, Field\n","\n","\n","class DocumentUpload(BaseModel):\n","    content: str\n","    metadata: dict | None = Field(default=None)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"OsGz_tAz-N_j","executionInfo":{"status":"ok","timestamp":1778301999938,"user_tz":-420,"elapsed":42,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"6e22711e-367e-4a3c-f543-38d541cd6824"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing document_upload.py\n"]}]},{"cell_type":"code","source":["# Переходим в папку Проекта\n","%cd {app_path}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"4nrV4SAqNjxc","executionInfo":{"status":"ok","timestamp":1778304626497,"user_tz":-420,"elapsed":23,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"4d5edb80-1264-4896-832b-355619223895"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Модуль 12/TUSUR/app\n"]}]},{"cell_type":"markdown","source":["## Создаём API\n","в директории `routers` создать файл `document_loader.py`, в котором пропишем сам API."],"metadata":{"id":"ujkGyiS0UjVt"}},{"cell_type":"code","source":["# Переходим в папку routers внутри app\n","%cd {app_path}/routers"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"GZwNyCTiWoBY","executionInfo":{"status":"ok","timestamp":1778403684278,"user_tz":-420,"elapsed":25,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"0cbecb05-6b66-42fe-ef80-acc3f5ea02f5"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Модуль 12/TUSUR/app/routers\n"]}]},{"cell_type":"code","source":["%%writefile document_loader.py\n","\n","import hashlib  # Импортируем стандартную библиотеку для генерации хэшей\n","\n","from dependencies import chroma, record_manager\n","from schemas.document_upload import DocumentUpload\n","\n","from fastapi import APIRouter, Body, Query  # Query нужен для необязательных параметров фильтрации\n","\n","\n","from langchain_core.indexing import aindex\n","from langchain_text_splitters import RecursiveCharacterTextSplitter\n","from langchain_core.documents import Document\n","\n","\n","router = APIRouter()\n","\n","text_splitter = RecursiveCharacterTextSplitter(\n","    chunk_size=100,\n","    chunk_overlap=20,\n","    length_function=len,\n","    is_separator_regex=False,\n","    separators=[\"\\n\", \"\\n\\n\", \".\"],\n",")\n","\n","@router.post(\n","    \"/load/chroma\",\n","    description=\"Загрузка документа с детерминированным ID для защиты от дубликатов\"\n",")\n","async def upload_document(document_input: DocumentUpload = Body()):\n","    # 1. Генерируем стабильный parent_doc_id на основе хэша текста (SHA-256)\n","    # Для одного и того же текста этот ID всегда будет одинаковым\n","    text_hash = hashlib.sha256(document_input.content.encode(\"utf-8\")).hexdigest()\n","    parent_id = text_hash\n","\n","    # 2. Формируем метаданные, которые будут уникальны для этого контента\n","    final_metadata = document_input.metadata.copy() if document_input.metadata else {}\n","    final_metadata[\"parent_doc_id\"] = parent_id\n","\n","    # 3. Нарезаем текст на чанки\n","    chunks: list[Document] = text_splitter.create_documents(\n","        texts=[document_input.content],\n","        metadatas=[final_metadata]\n","    )\n","\n","    # 4. Передаем данные в aindex. Теперь при повторном запросе хэши чанков сойдутся,\n","    # и record_manager заблокирует дублирование в Chroma\n","    out = await aindex(\n","        chunks,\n","        record_manager=record_manager,\n","        vector_store=chroma\n","    )\n","\n","    return {\n","        \"index_status\": out,\n","        \"parent_doc_id\": parent_id\n","    }\n","\n","@router.get(\n","    \"/get/documents\",\n","    description=\"Получить список всех чанков и их метаданных, записанных в Chroma\"\n",")\n","async def get_stored_documents(\n","    parent_doc_id: str | None = Query(default=None, description=\"Фильтр по ID родительского документа\"),\n","    limit: int = Query(default=10, description=\"Количество выводимых чанков\")\n","):\n","    try:\n","        # 1. Формируем фильтр, если клиент передал parent_doc_id\n","        where_filter = {\"parent_doc_id\": parent_doc_id} if parent_doc_id else None\n","\n","        # 2. Делаем прямой запрос к коллекции Chroma через метод .get()\n","        # Извлекаем тексты (documents) и метаданные (metadatas)\n","        result = chroma.get(\n","            where=where_filter,\n","            limit=limit,\n","            include=[\"documents\", \"metadatas\"]  # Можно добавить \"embeddings\", если нужны сами векторы-числа\n","        )\n","\n","        # 3. Форматируем ответ для удобного чтения на фронтенде или в Swagger\n","        formatted_chunks = []\n","        if result and \"documents\" in result:\n","            for idx in range(len(result[\"ids\"])):\n","                formatted_chunks.append({\n","                    \"chunk_id\": result[\"ids\"][idx],\n","                    \"text\": result[\"documents\"][idx],\n","                    \"metadata\": result[\"metadatas\"][idx] if result[\"metadatas\"] else {}\n","                })\n","\n","        return {\n","            \"total_fetched\": len(formatted_chunks),\n","            \"chunks\": formatted_chunks\n","        }\n","\n","    except Exception as e:\n","        raise HTTPException(status_code=500, detail=f\"Ошибка чтения из Chroma: {str(e)}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"t4w56cwvUjpK","executionInfo":{"status":"ok","timestamp":1778403695419,"user_tz":-420,"elapsed":325,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"6030d805-5009-42ab-c086-b26232dc7364"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Overwriting document_loader.py\n"]}]},{"cell_type":"code","source":["# Переходим в папку Проекта\n","%cd {app_path}"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778403725663,"user_tz":-420,"elapsed":44,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"f82dae1c-701d-4b29-8609-4559e3f46641","id":"29tDxBUdWynj"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/Colab Notebooks/ТУСУР/Искусственный интеллект. Алгоритмы машинного обучения на языке Python (2025)/Модуль 12/TUSUR/app\n"]}]},{"cell_type":"markdown","source":["## Тест API"],"metadata":{"id":"hrArLxK2gCGc"}},{"cell_type":"code","source":["%%writefile test_api_document_loader.py\n","\n","from fastapi import FastAPI\n","from routers.document_loader import router  # Импорт роутера из файла\n","\n","app = FastAPI(title=\"Документация Chroma Indexer\")\n","\n","# Подключаем роутер\n","app.include_router(router)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"h8-wgL_LgJfI","executionInfo":{"status":"ok","timestamp":1778310658248,"user_tz":-420,"elapsed":16,"user":{"displayName":"Максим Митющенко","userId":"03491934236834573340"}},"outputId":"b10c49ab-f991-4735-9958-a1e7e7db4b8f"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Writing test_api_document_loader.py\n"]}]},{"cell_type":"markdown","source":["# Шаг 2: RAG по всем документам"],"metadata":{"id":"WEu7uC7aaUMK"}},{"cell_type":"markdown","source":["## Схема запроса пользователя\n","\n","чтобы стандартизировать формат ввода запросов от клиента, создадим схему, по которой будет строиться Request Body в файле `search_query.py`.\n","\n","Клиент может как задавать вопрос, так и добавлять уточняющие метаданные для поиска."],"metadata":{"id":"dls3c2tig2yh"}},{"cell_type":"code","source":["# Переходим в папку schemas внутри app\n","